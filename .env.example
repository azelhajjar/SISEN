# ─────────────────────────────────────────────────────────────
# SISEN — Controlled Realistic Infrastructure Scenario Platform
# Central Configuration File
#
# Copy this file to .env and edit it for your environment:
#   cp .env.example .env
#
# The .env file is loaded automatically by all scripts.
# Never commit your .env file to version control.
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────
# Tool Identity
# ─────────────────────────────────────────
TOOL_NAME="SISEN"
TOOL_VERSION="1.0-MVP"

# ─────────────────────────────────────────
# Institution / Course (optional)
# Set these if deploying for a specific course or institution.
# Leave as-is for generic/public use.
# ─────────────────────────────────────────
COURSE_CODE="LAB"
COURSE_NAME="Wireless Network Security"
INSTITUTION="Your Institution"

# ─────────────────────────────────────────
# Wireless Interface
# Set INTERFACE to your physical wireless adaptor name.
# Run: iw dev   to find your interface name.
# ─────────────────────────────────────────
INTERFACE="wlan0"
REGDOM="GB"

# ─────────────────────────────────────────
# Network Addressing
# ─────────────────────────────────────────
AP_IP="192.168.140.1/24"
AP_IP_BASE="192.168.140.1"
RUNTIME_DIR="/tmp/SISEN"

# ─────────────────────────────────────────
# SSID Naming
# SSIDs are auto-generated as: SSID_PREFIX-<TYPE>-AP
# Example: LAB-OPEN-AP, LAB-WPA2-AP, LAB-WPA2E-AP
# ─────────────────────────────────────────
SSID_PREFIX="${COURSE_CODE}"

# ─────────────────────────────────────────
# AP Passwords
# Change these before deploying in any environment.
# ─────────────────────────────────────────
WPA_PASSPHRASE="changeme123"
WEP_KEY="AABBCCDDEE"

# ─────────────────────────────────────────
# RADIUS / WPA2-Enterprise
# ─────────────────────────────────────────
RADIUS_SECRET="changeme-radius-secret"
RADIUS_ADDR="127.0.0.1"
RADIUS_PORT="1812"

# RADIUS user accounts (username:password)
RADIUS_USER1_NAME="alice"
RADIUS_USER1_PASS="Password1!"
RADIUS_USER2_NAME="bob"
RADIUS_USER2_PASS="Password2!"
RADIUS_USER3_NAME="charlie"
RADIUS_USER3_PASS="Password3!"

# ─────────────────────────────────────────
# SISEN Scenario Settings
# (used by run_scenario.py and the orchestrator)
# ─────────────────────────────────────────
SCENARIO_DEFAULT="scada"
SCENARIO_RUNTIME_DIR="/tmp/SISEN/scenarios"
